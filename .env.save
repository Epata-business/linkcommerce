# --- Base de Dados ---
DATABASE_URL="postgresql://user:password@localhost:5432/linkcommerce?schema=public"

# --- NextAuth.js ---
AUTH_SECRET="gera-com: npx auth secret"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Domínio (multi-tenant por subdomínio) ---
