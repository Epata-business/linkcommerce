# --- Stripe (pagamentos + subscrições de plano) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- IA (bónus: sugestões de loja, descrições de produto, posts) ---
ANTHROPIC_API_KEY=""

# --- Apenas para o ambiente de demonstração do POS ---
