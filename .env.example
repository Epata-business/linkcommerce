# ─────────────────────────────────────────────
# LinkCommerce · Epata Lda — Variáveis de Ambiente
# Copie este ficheiro para .env e preencha os valores
# ─────────────────────────────────────────────

# ── Base de dados (Neon PostgreSQL gratuito: neon.tech) ──
DATABASE_URL="postgresql://user:password@host/linkcommerce?sslmode=require"

# ── NextAuth (gerar com: npx auth secret) ──
AUTH_SECRET=""
GOOGLE_CLIENT_ID=""       # opcional — login com Google
GOOGLE_CLIENT_SECRET=""   # opcional

# ── Domínio multi-tenant ──
NEXT_PUBLIC_ROOT_DOMAIN="linkcommerce.app"  # em dev: localhost:3000

# ── Stripe (pagamentos) — stripe.com ──
# Chaves de teste começam com sk_test_ e pk_test_
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""                    # gerado em: stripe listen --forward-to localhost:3000/api/webhook/stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ── Cloudinary (upload de imagens) — cloudinary.com ──
# Plano gratuito: 25 GB armazenamento
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Resend (emails transacionais) — resend.com ──
# Plano gratuito: 3000 emails/mês
RESEND_API_KEY=""
EMAIL_FROM="LinkCommerce <noreply@linkcommerce.app>"   # verificar domínio no Resend

# ── Claude / Anthropic (IA para lojistas) — console.anthropic.com ──
ANTHROPIC_API_KEY=""

# ── POS demo ──
NEXT_PUBLIC_DEMO_LOJA_ID=""
